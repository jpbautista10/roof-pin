PORT=3000
PING_MESSAGE=ping

VITE_APP_URL=http://localhost:8080
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Client-side Mapbox token for rendering maps in the browser.
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# Server-side Mapbox token used by /api/geocode/suggest.
# You can use a secret token here for stricter control.
MAPBOX_ACCESS_TOKEN=sk.your_mapbox_server_token

# Support contact form (POST /api/support) — Resend. Without these, the API returns 503.
# https://resend.com/docs/api-reference/emails/send-email
RESEND_API_KEY=re_your_resend_key
RESEND_FROM=onboarding@resend.dev
# Inbox for support messages (default if unset: support@roofwisepro.com)
SUPPORT_TO_EMAIL=support@roofwisepro.com
